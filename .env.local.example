# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rinwa-db

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Gmail SMTP Configuration (use a Google App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM="RÌNWÁ Hospitality <your-gmail-address@gmail.com>"

# Admin Credentials (for initial seed)
ADMIN_EMAIL=admin@rinwahospitality.com
ADMIN_PASSWORD=secure-password-here

# Public Site URL (for SEO, social sharing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
